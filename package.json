{
  "name": "website-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "next start",
    "lint": "eslint --max-warnings=0",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docker:build": "docker compose --env-file .env build",
    "docker:up": "docker compose --env-file .env up -d --build",
    "docker:down": "docker compose --env-file .env down",
    "docker:up:lb": "docker compose --env-file .env down --remove-orphans && docker compose -f docker-compose.nginx.yml --env-file .env up -d --build --remove-orphans",
    "docker:down:lb": "docker compose -f docker-compose.nginx.yml --env-file .env down --remove-orphans",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "axios": "^1.7.4",
    "bcryptjs": "^3.0.3",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^3.15.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
