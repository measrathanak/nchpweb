# Project ports
WEB_PORT=3000
TYPO3_PORT=8888

# Next.js public URL (used for metadata + canonical links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Headless TYPO3 API target used by Next.js API routes
TYPO3_API_BASE_URL=http://localhost:8888/typo3rest
TYPO3_API_USERNAME=admin
TYPO3_API_PASSWORD=password
TYPO3_API_REVALIDATE_SECONDS=300

# Locale fallback used by route proxy
DEFAULT_LOCALE=en

# Authentication and role allowlists
NEXTAUTH_SECRET=change-me-in-production
ADMIN_EMAILS=demo@npch.local,admin@npch.local
EDITOR_EMAILS=

# Postgres for Prisma/NextAuth
DATABASE_URL=postgresql://npch_user:npch_password@localhost:5432/npch_website?schema=public
# Used by docker-compose services to connect back to Postgres running on your Mac host.
DOCKER_DATABASE_URL=postgresql://npch_user:npch_password@host.docker.internal:5432/npch_website?schema=public

# Redis
REDIS_PORT=6379
# Used by local host-run apps (for example: npm run dev)
REDIS_URL=redis://localhost:6379
# Used by docker-compose services to connect to Redis container
DOCKER_REDIS_URL=redis://redis:6379

# Optional secure revalidation endpoint secret
REVALIDATE_SECRET=change-me
REVALIDATE_TIMESTAMP_TOLERANCE_SECONDS=300
REVALIDATE_BASE_URL=http://localhost:${WEB_PORT}
