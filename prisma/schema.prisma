// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// User & Authentication Models
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  firstName     String?
  lastName      String?
  phone         String?
  password      String? // hashed password if local auth
  avatar        String?
  language      String    @default("en") // Preferred language: en, km
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions        Session[]
  preferences     UserPreferences?
  savedArticles   SavedArticle[]
  formSubmissions FormSubmission[]
  roleAssignments UserRoleAssignment[]

  @@index([email])
  @@map("users")
}

model Session {
  id            String    @id @default(cuid())
  sessionToken  String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires       DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([sessionToken])
  @@map("sessions")
}

model UserPreferences {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Content preferences
  favoriteCategories String[] @default([]) // Category slugs
  articlesPerPage Int      @default(10)
  notificationsEnabled Boolean @default(true)
  
  // Theme & accessibility
  theme         String    @default("light") // light, dark
  fontSize      String    @default("medium") // small, medium, large
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("user_preferences")
}

// ============================================================================
// Content Models
// ============================================================================

model SavedArticle {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // TYPO3 Article reference
  typo3ArticleUid Int
  title         String
  slug          String
  language      String    @default("en")
  
  savedAt       DateTime  @default(now())

  @@unique([userId, typo3ArticleUid, language])
  @@index([userId])
  @@index([typo3ArticleUid])
  @@map("saved_articles")
}

model SearchCache {
  id            String    @id @default(cuid())
  query         String
  language      String    @default("en")
  results       Json      // Store Solr search results
  resultCount   Int       @default(0)
  
  // Cache control
  createdAt     DateTime  @default(now())
  expiresAt     DateTime  // Invalidate after this time
  hits          Int       @default(0) // How many times this cache was used
  
  @@unique([query, language])
  @@index([expiresAt])
  @@index([language])
  @@map("search_cache")
}

// ============================================================================
// Role Management
// ============================================================================

model Role {
  id              String   @id @default(cuid())
  name            String   @unique
  permissions     String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userAssignments UserRoleAssignment[]

  @@map("roles")
}

model UserRoleAssignment {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role_assignments")
}

// ============================================================================
// Form Submissions
// ============================================================================

model FormSubmission {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Form metadata
  formType      String    // "contact", "newsletter", "feedback"
  formData      Json      // Store all form fields dynamically
  
  // Contact info
  email         String
  name          String?
  phone         String?
  
  // Status
  status        String    @default("pending") // pending, reviewed, resolved
  notes         String?   // Admin notes
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([formType])
  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("form_submissions")
}

// ============================================================================
// Analytics Models
// ============================================================================

model PageView {
  id            String    @id @default(cuid())
  userId        String?   // Anonymous if null
  
  // Page info
  path          String
  title         String?
  referrer      String?
  language      String    @default("en")
  
  // Device info
  userAgent     String?
  ipAddress     String?   // Anonymized if applicable
  
  // Timing
  loadTime      Int?      // milliseconds
  timestamp     DateTime  @default(now())

  @@index([userId])
  @@index([path])
  @@index([language])
  @@index([timestamp])
  @@map("page_views")
}

// ============================================================================
// Languages
// ============================================================================

model Language {
  id            String    @id @default(cuid())
  name          String    @unique
  code          String    @unique // e.g., "en", "km", "zh"
  nativeName    String?   // e.g., "ខ្មែរ", "中文"
  flagEmoji     String?   // e.g., "🇰🇭", "🇨🇳"
  enabled       Boolean   @default(true)
  sortOrder     Int       @default(999)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("languages")
}

// ============================================================================
// Login Audit Logs
// ============================================================================

model LoginAudit {
  id            String    @id @default(cuid())
  userId        String?   // Null if login failed before user was identified
  email         String    // Email used for login attempt
  status        String    // "success", "failed"
  reason        String?   // Why it failed: "invalid_credentials", "account_locked", etc.
  
  // Device & Location
  ipAddress     String?
  userAgent     String?
  latitude      Float?
  longitude     Float?
  
  timestamp     DateTime  @default(now())

  @@index([email])
  @@index([status])
  @@index([timestamp])
  @@map("login_audits")
}

// ============================================================================
// Content Queue (for background jobs)
// ============================================================================

model ContentQueue {
  id            String    @id @default(cuid())
  action        String    // "cache_article", "clear_search", "send_notification"
  status        String    @default("pending") // pending, processing, completed, failed
  
  payload       Json      // Store action-specific data
  error         String?   // Error message if failed
  
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([action])
  @@index([createdAt])
  @@map("content_queue")
}
